  <string name="server_center">Switch Server</string>
  <string name="server_center_footer_text">Why does data exist across multiple servers? \n Your account data might exist across multiple servers due to cross-server home/device sharing or other operational activities. \n\n What is the impact of data being stored on different servers? \n Data is isolated between servers, so you cannot view homes or devices from Server 2 while on Server 1. This might inconvenience your daily use. Unless necessary, it is recommended to delete accounts under inactive servers.</string>
  <string name="server_center_header_text">Tap to switch to another server</string>
  <string name="server_switch_confirm_alert_content">After switching, your account data on this server, including homes, devices, and scenes, will become invisible and unavailable in %s. Continue?</string>
  <string name="server_switch_confirm_alert_title">Are you sure to switch to %s?</string>
  <string name="server_switch_generate_error">Failed to switch to the specified server.</string>
  <string name="server_switch_loading_text_one">Disconnecting from %s. Current home and device data will be disconnected.</string>
  <string name="server_switch_loading_text_two">Loading home, device, and other data from %s.</string>
  <string name="server_switch_loading_title">Switching %s%%. Please wait.</string>
  <string name="server_switch_multi_login_confirm_alert_content">Your account has logged in to %s device(s), including mobile phones, pads, and control panels. After you switch to another server, all these devices will be logged out and you need to log in again to continue using them on the new server. Continue?</string>
  <string name="server_switch_multi_login_confirm_alert_title">Your account will be logged out on other devices.</string>
  <string name="server_switch_next">Continue Anyway</string>
  <string name="server_switch_notice_text">Your account has switched to using the home and device data of \"%s\" on another device. To continue using the previous homes or devices, you can go to Settings &gt; Account and Security and switch back to the previous server.</string>
